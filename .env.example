# Production example for styles-testing-survey.
# Copy to /etc/styles-testing-survey.env on the server and fill real values.
NODE_ENV=production
PORT=3000
# Keep the app reachable only from the local reverse proxy by default.
HOST=127.0.0.1

# PostgreSQL connection string. Use a dedicated DB user with privileges only for this app DB.
DATABASE_URL=postgres://styles_survey:change-me@127.0.0.1:5432/styles_survey

# Generate both secrets separately, for example with: openssl rand -hex 32
ADMIN_TOKEN=change-this-to-a-long-random-token
# Separate key used to sign the anonymous voter cookie.
SURVEY_COOKIE_SECRET=change-this-to-another-long-random-secret
# Admin browser session lifetime in seconds. Default: 8 hours.
ADMIN_SESSION_TTL_SECONDS=28800

# Reverse proxy / HTTPS hardening.
# If nginx runs on the same machine, loopback is the safest trust proxy setting.
TRUST_PROXY=loopback
# Nginx HTTPS template already redirects HTTP to HTTPS. Set true after HTTPS proxy works
# if you also want app-layer redirects for requests that reach Node directly.
ENFORCE_HTTPS=false
ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost

# Optional PostgreSQL TLS verification for managed DBs.
# Leave PGSSLMODE empty for local Postgres without TLS.
# PGSSLMODE=require
# PGSSLREJECTUNAUTHORIZED=true
# PGSSLCAFILE=/etc/ssl/certs/ca-certificates.crt
# PGSSLROOTCERT=/etc/ssl/certs/ca-certificates.crt

# 0 disables the in-memory limit. Defaults: submissions 30/hour, admin login 10/15min, admin API 60/15min.
SUBMISSION_RATE_LIMIT=30
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_RATE_LIMIT=60
